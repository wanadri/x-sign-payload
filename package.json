{
  "name": "x-sign-payload",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-language HMAC-SHA256/SHA512 payload signing monorepo",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "docs:dev": "cd docs && npm run docs:dev",
    "docs:build": "cd docs && npm run docs:build",
    "php:test": "cd packages/php && composer test",
    "js:test": "cd packages/js && npm test"
  },
  "devDependencies": {
    "turbo": "^1.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wanadri/x-sign-payload.git"
  },
  "license": "MIT",
  "author": "wanadri"
}
