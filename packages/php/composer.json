{
    "name": "wanadri/x-sign-payload",
    "description": "Secure HMAC-SHA256/SHA512 payload signing and verification for PHP frameworks",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "signature",
        "hmac",
        "security",
        "payload",
        "verification",
        "laravel",
        "cakephp",
        "codeigniter"
    ],
    "authors": [
        {
            "name": "wanadri",
            "email": "your@email.com"
        }
    ],
    "require": {
        "php": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "Wanadri\\XSignPayload\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wanadri\\XSignPayload\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wanadri\\XSignPayload\\Frameworks\\Laravel\\XSignPayloadServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src tests --level=8",
        "lint": "phpcs src tests --standard=PSR12",
        "lint-fix": "phpcbf src tests --standard=PSR12"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
